# ============================================================
# FTIR Zeolitas UAS - Configuración del Backend
# Copia este archivo como .env y configura los valores
# ============================================================

# --- Seguridad JWT ---
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria-segura

# --- Base de datos (SQLite por defecto, no requiere instalación) ---
DATABASE_URL=sqlite:///./ftir_zeolitas.db

# --- SMTP (Correo electrónico para verificación) ---
# Para Gmail: usa una "App Password" (no tu contraseña normal)
# Ve a: Google Account > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-caracteres

# --- Remitente del correo ---
FROM_EMAIL=tu-correo@gmail.com
FROM_NAME=FTIR Zeolitas UAS

# --- URL del frontend Angular ---
FRONTEND_URL=http://localhost:4200

# --- Expiración de tokens ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
